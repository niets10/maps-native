# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings -> API). These are safe to expose client-side because
# Row Level Security policies protect the actual data (see supabase/schema.sql).

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed if you enable Google sign-in (Supabase Dashboard -> Authentication -> Providers -> Google).
# See the README for the full setup steps.
